<GuiXml>
    <Controls>
        <TopLevelControl name="StaggerTrackerControl" clampedToScreen="true" mouseEnabled="true" movable="true" hidden="true">
            <Dimensions x="64" y="64" />
            <Anchor point="CENTER" relativeTo="GuiRoot" relativePoint="CENTER" offsetX="0" offsetY="-200" />
            <OnMoveStop>StaggerTracker.Move()</OnMoveStop>
            <Controls>
				<Texture name="$(parent)_BG" color="FF0000" alpha="1">
					<Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" />
					<Dimensions x="64" y="64" />
				</Texture>
				<Texture name="$(parent)_Icon">
					<Anchor point="CENTER" relativeTo="$(parent)" relativePoint="CENTER" />
					<Dimensions x="54" y="54"/>
				</Texture>
                <Label name="$(parent)_Duration" font="$(MEDIUM_FONT)|$(KB_40)|thick-outline" inheritAlpha="true" color="FFFFFF" wrapMode="TRUNCATE" verticalAlignment="CENTER" horizontalAlignment="CENTER" text="0">
                    <Anchor point="CENTER" relativeTo="$(parent)" relativePoint="CENTER" offsetX="0" offsetY="0" />
                </Label>
                <Label name="$(parent)_Stacks" font="$(MEDIUM_FONT)|$(KB_22)|thick-outline" inheritAlpha="true" color="FFFFFF" wrapMode="TRUNCATE" text="0">
                    <Anchor point="TOPRIGHT" relativeTo="$(parent)" relativePoint="TOPRIGHT" offsetX="-7" offsetY="1" />
                </Label>
            </Controls>
        </TopLevelControl>
    </Controls>
</GuiXml>